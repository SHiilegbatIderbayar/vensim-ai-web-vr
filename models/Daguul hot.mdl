{UTF-8}
Сургуулийн насны хүүхэд=
	Хүн ам*0.23
	~	
	~		|

Шаардлагатай сургуулийн тоо=
	Сургуулийн насны хүүхэд/940
	~	
	~	Нэг сургуулийг 940 хүүхдийн хүчин \
		чадалтайгаар тооцсон
	|

Шаардлагатай цэцэрлэгийн тоо=
	Цэцэрлэгийн насны хүүхэд/240
	~	
	~	Нэг цэцэрлэгийн хүчин чадлыг 240 хүүхдийн \
		чадлаар тооцсон
	|

Цэцэрлэгийн насны хүүхэд=
	Хүн ам*0.1
	~	
	~		|

Нийт хүн ам=
	Ажиллах хүч+Бусад хүн ам+Сургуулийн насны хүүхэд\
		+Цэцэрлэгийн насны хүүхэд
	~	
	~		|

Бусад хүн ам=
	Хүн ам*0.37
	~	
	~		|

Аж ахуйн нэгжийн эрхлэх газар=
	Аж ахуйн нэгжийн бүс
	~	km*km
	~	Талбай*Бизнесийн газрын хэсэг
	|

Байшин барих газар=
	Суурьшлийн бүс
	~	km*km
	~	Байшингийн газрын хэсэг*Талбай
	|

Аж ахуйн нэгж=
	(ААН*Аж ахуйн нэгж нэмэгдэх*Аж ахуйн нэгжийн татах чадвар\
		)+Нийт нэмэгдэх аж ахуйн нэгж
	~	company/Year
	~		|

Аж ахуйн нэмэгдэх он=
	0
	~	 [0,1,1]
	~		|

Нэмэгдэх аж ахуйн нэгж(
	[(0,0)-(10,10)],(2,55),(3,70),(4,70),(5,70),(6,70),(7,70),(8,0))
	~	 [0,1000,10]
	~		|

Нийт нэмэгдэх аж ахуйн нэгж=
	IF THEN ELSE(Аж ахуйн нэмэгдэх он=1, Нэмэгдэх аж ахуйн нэгж\
		(Time) , 0 )
	~	
	~	IF THEN ELSE(Time=Аж ахуйн нэмэгдэх он, Нэмэгдэх \
		аж ахуйн нэгж, 0)
	|

Бизнесийн татвар=
	Безнесийн бүтцэд ногдох татвар*ААН
	~	tax/company
	~		|

ААН ийн өсөх чадвар= WITH LOOKUP (
	Ажиллах хүчний ажлын харьцаа,
		([(0,0)-(10, 0)], (0,0.2), (0.2,0.25), (0.4,0.35),
		(0.6,0.5), (0.8,0.7), (1,1), (1.2,1.35), (1.4,1.6), (1.6,1.8), (1.8,1.95), (2,2)))
	~	Dmnl
	~		|

Аж ахуйн нэгжийн татах чадвар=
	ААН ийн өсөх чадвар*Аж ахуйн нэгжийн татах чадвар газрын нөлөө\
		*Хүртээмжтэй байдал
	~	Dmnl
	~		|

Татах чадвар=
	Үйлчилгээний байгууламжийн татах чадар*Боловсролын татах чадвар\
		*Орон сууцны татах чадвар*ААН ийн татах чадвар
	~	Dmnl
	~		|

Орон сууцны татах чадвар нэмэх=
	Орон сууцны газрын татах чадвар
	~	Dmnl
	~		|

Орон сууцны газрын татах чадвар= WITH LOOKUP (
	Байшингийн газрын эзэмшил хэсэг,
		([(0,0)-(1,2)], (0,0.4), (0.1,0.7), (0.2,1), (0.3,1.25),
		(0.4,1.45), (0.5,1.5), (0.6,1.5), (0.7,1.4), (0.8,1), (0.9,0.5), (1,0)))
	~	Dmnl
	~		|

ААН ийн татах чадвар= WITH LOOKUP (
	Ажиллах хүчний ажлын харьцаа,
		([(0, 0)-(10,10)], (0, 2), (0.2,1.95), (0.4,1.8),
		(0.6,1.6), (0.8,1.35), (1, 1), (1.2,0.5), (1.4,0.3), (1.6,0.2), (1.8,0.15), (2,0.1)\
		))
	~	Dmnl
	~		|

Аж ахуйн нэгжийн бүтэц бүрт газар=
	0.002
	~	km*km/company
	~		|

Аж ахуйн нэгжийн эзэмших газар=
	(ААН*Аж ахуйн нэгжийн бүтэц бүрт газар)/Аж ахуйн нэгжийн эрхлэх газар
	~	Dmnl
	~		|

Ажиллах хүч=
	Хүн ам*Хөдөлмөрийн оролцоо
	~	people
	~		|

Ажиллах хүчний ажлын харьцаа=
	Ажиллах хүч/Ажлын байр
	~	Dmnl
	~		|

Ажлын байр=
	ААН*Нэг ААН хамаарах ажлын байр
	~	people
	~		|

Анхны аж ахуйн нэгж=
	125
	~	company
	~		|

Анхны орон сууц=
	2660
	~	house
	~	2660
	|

Анхны хүн ам=
	7625
	~	people
	~	7625
	|

Орон сууц= INTEG (
	Орон сууц барих-Орон сууц нураах,
		Анхны орон сууц)
	~	house
	~		|

Байшин бүрт газар=
	0.006
	~	km*km/house
	~	0.001
	|

"Байшин, өрхийн харьцаа"=
	Орон сууц/Тэнцвэртэй орон сууцны тоо
	~	Dmnl
	~		|

Суурьшлийн бүс=
	243
	~	km*km
	~		|

Байшингийн газрын эзэмшил хэсэг=
	(Байшин бүрт газар*Орон сууц)/Байшин барих газар
	~	Dmnl
	~		|

Нийт талбай=
	333
	~	km*km
	~		|

Аж ахуйн нэгжийн бууралт=
	Аж ахуйн нэгж буурах хувь*ААН
	~	company/Year
	~		|

Нэг ААН хамаарах ажлын байр=
	20
	~	people/company
	~		|

ААН= INTEG (
	Аж ахуйн нэгж-Аж ахуйн нэгжийн бууралт,
		Анхны аж ахуйн нэгж)
	~	company
	~		|

Аж ахуйн нэгжийн бүс=
	90
	~	km*km
	~		|

Аж ахуйн нэгжийн татах чадвар газрын нөлөө= WITH LOOKUP\
		 (
	Аж ахуйн нэгжийн эзэмших газар,
		([(0, 0)-(10, 10)], (0, 1), (0.1,1.15), (0.2,1.3),
		(0.3,1.4), (0.4, 1.45), (0.5,1.4), (0.6,1.3), (0.7,0.9), (0.8,0.5), (0.9, 0.25), (1\
		,0)))
	~	Dmnl
	~		|

Шаардлагатай үйлчилгээний байгууламж=
	Объектив үйлчилгээний байгууламж-Үйлчилгээний байгууламж чанар
	~	sf
	~		|

Шилжин ирэлт=
	(Ирээдүйн шилжин ирэх хүн ам+Хүн ам)*Ердийн шилжин ирэлт\
		*Татах чадвар
	~	people/Year
	~		|

Шилжин явалт=
	Ердийн шилжин явалт*Хүн ам
	~	people/Year
	~		|

Ердийн орон сууц нураах=
	0.04
	~	1/Year
	~		|

Үйлчилгээний байгууламж чанар= INTEG (
	Үйлчилгээний байгууламж барих-Үйлчилгээний байгууламж нураах\
		,
		Анхны үйлчилгээний байгууламжийн чанар)
	~	Dmnl
	~		|

Үйлчилгээний байгууламж барих=
	Шаардлагатай үйлчилгээний байгууламж*Үйлчилгээний байгууламж барих дундаж
	~	sf/Year
	~		|

Үйлчилгээний байгууламж нураах=
	Үйлчилгээний байгууламжийн дундаж*Үйлчилгээний байгууламж чанар
	~	sf/Year
	~		|

